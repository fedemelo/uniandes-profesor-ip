% Placeholder: caja inline para representar partes de código
% Uso: \placeholder{condición} o \placeholder[descripción]{condición}
\newtcbox{\placeholder}[1][]{%
	on line,
	colback=violet!8,
	% colframe=violet!40!black,
	colframe=white,
	boxrule=0.5pt,
	arc=2pt,
	boxsep=0pt,
	left=3pt,
	right=3pt,
	top=2pt,
	bottom=2pt,
	fontupper=\ttfamily\itshape,
	#1
}

