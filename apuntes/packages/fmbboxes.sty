% Customization of itemize environment
\renewcommand{\labelitemi}{\( \bullet \)} % Item level 1: Bullet.
\renewcommand{\labelitemii}{\( \circ \)} % Item level 2: Circunference.
\renewcommand{\labelitemiii}{\( \diamond \)} % Item level 3: Diamond.
\renewcommand{\labelitemiv}{\(\triangleright\)} % Item level 4: Triangle (right).


% Tabla APA

\newcounter{tablaapa} % Counter de tablaapa

\NewDocumentEnvironment{tablaapa}{m m m}{%
	\par \addvspace{\baselineskip} \noindent \begin{minipage}{\textwidth}
		\refstepcounter{tablaapa} 
		\noindent \textbf{Tabla \thetablaapa} \hypertarget{tabapa:#2}{} \label{tabapa:#2} \\
		\textit{#1} \\
		\begin{tabular}{#3}}{%
		\end{tabular}
	\end{minipage} \par \addvspace{\baselineskip}
}

\newcommand{\tablaapaautorefname}{Tabla} % Autoref tablaapa

