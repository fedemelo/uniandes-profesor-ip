% Teorema (VERDE) con prueba

\newcounter{teorema} % Counter de teorema
\renewcommand\theteorema{\arabic{section}.\arabic{teorema}}
\counterwithin*{teorema}{section} % Restarts theteorema every time the section changes.

\NewDocumentEnvironment{teorema}{m m o}{%
	\refstepcounter{teorema}
	\hypertarget{thm:#2}{}
	\label{thm:#2}
	\begin{tcolorbox}[%
		title=Teorema \theteorema. #1,
		colback=white, 
		colframe=green!30!black, 
		breakable,
		enhanced, 
		sharp corners=northwest, 
		fonttitle=\bfseries\sffamily, 
		drop fuzzy shadow southeast,
		attach boxed title to top left={
			xshift=1cm,
			yshift*=1mm-\tcboxedtitleheight}, 
		before skip=2mm,
		after skip=4mm, 
		boxrule=0.4mm, 
		boxed title style={ 
			frame code={
				\path[fill=tcbcolback!50!black]
				([yshift=-1mm,xshift=-1mm]frame.north west)
				arc[start angle=0,end angle=180,radius=1mm]
				([yshift=-1mm,xshift=1mm]frame.north east)
				arc[start angle=180,end angle=0,radius=1mm];
				\path[left color=tcbcolback!60!black,
				right color=tcbcolback!60!black,
				middle color=tcbcolback]
				([xshift=-2mm]frame.north west) -- ([xshift=2mm]frame.north east)
				[rounded corners=1mm]-- ([xshift=1mm,yshift=-1mm]frame.north east)
				-- (frame.south east) -- (frame.south west)
				-- ([xshift=-1mm,yshift=-1mm]frame.north west)
				[sharp corners]-- cycle;}},
		colbacktitle=green!30!black,
		subtitle style={colback=green!30!black!75!white},
		before lower=\textbf{\textsf{Prueba:~}},
		after lower=\hfill \textit{\footnotesize{Quod erat demonstrandum.}}%
		]%
		\it % Theorems in italics.
	}{%
		\IfNoValueTF{#3}% If there's no optional parameter, do nothing.
		{}%
		{\tcblower#3}% If there is optional parameter, it's the demonstration. Add it under the theorem with tcblower.
	\end{tcolorbox}
}

\newcommand{\teoremaautorefname}{teorema} % Autoref teorema

