% Notación

\NewDocumentEnvironment{notacion}{O{}}{%
	\begin{tcolorbox}[
		enhanced,
		before skip =2mm,
		after skip =3mm,
		boxrule=0.8pt,
		left=10mm,
		right=1mm,
		top=1mm,
		bottom=1mm,
		colback=white,
		colframe=pink!80!white!90!black,
		sharp corners,
		rounded corners=southeast,
		arc is angular,arc=3mm,
		before upper= \textbf{\textsf{\textcolor{pink!90!black}{Notación.\quad}}},
		underlay={%
			\path[fill=tcbcolframe!90!black] ([yshift=3mm]interior.south east)--++(-0.4,-0.1)--++(0.1,-0.2);
			\path[draw=tcbcolframe,shorten <=-0.05mm,shorten >=-0.05mm] ([yshift=3mm]interior.south east)--++(-0.4,-0.1)--++(0.1,-0.2);
			\path[fill=tcbcolframe,draw=none] (interior.south west) rectangle node[white]{\LARGE \bfseries \faicon{superscript}} ([xshift=7mm]interior.north west);
		},
		drop fuzzy shadow,#1]
	}{%
	\end{tcolorbox}
}

